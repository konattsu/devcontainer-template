// wslからの起動が安定しない問題の解決方法
// wsl> `code .`
// vscodeが立ち上がるので, その上でrebuild and reopen in container
// wsl> `sudo systemctl restart docker`
// vscode側で接続が切れた旨の通知, reload windowsを促されるので従う
// vscodeで`rebuild`, 直る

{
  "name": "Devcontainer",
  "service": "dev-container",
  "workspaceFolder": "/workspaces",
  "dockerComposeFile": "./compose.yml",

  // "features": {
  //   // ref: https://containers.dev/features
  // },

  // "mounts": [
  //   "source=pnpm-store,target=/home/node/.local/share/pnpm/store,type=volume"
  // ],

  "customizations": {
    "vscode": {
      "extensions": [
        // markdown
        "davidanson.vscode-markdownlint",
        "bierner.markdown-mermaid",

        // git/github
        "donjayamanne.githistory",
        "eamodio.gitlens",
        "github.copilot",
        // "github.vscode-github-actions",
        "mhutchie.git-graph",

        // others
        "asuka.insertnumbers",
        "christian-kohler.path-intellisense",
        "editorconfig.editorconfig",
        "esbenp.prettier-vscode",
        "gruntfuggly.todo-tree",
        "mosapride.zenkaku",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "shardulm94.trailing-spaces",
        "streetsidesoftware.code-spell-checker",
        "wmaurer.change-case"
      ]
    }
  }
}
